{
  "name": "GAIME",
  "image": "mcr.microsoft.com/devcontainers/java:21-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/android-sdk:1": {}
  },
  "onCreateCommand": "bash scripts/setup-gl.sh",
