# Art / audio are now tracked via Git LFS (see .gitattributes):
#   *.png *.gif *.aseprite *.tmx *.tsx *.otf *.ttf *.wav *.ogg *.mp3
# so they are intentionally NOT ignored here anymore.

# Heavy editing sources & vendor promo junk we never load at runtime.
# (Recoverable from the original asset zips if ever needed.)
*.psd
*.svg
**/COUPON.pdf
**/COUPON.png
**/*.url

# Extracted audio archives (temporary)
.extracted/
