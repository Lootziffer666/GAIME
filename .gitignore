# Large archives / split parts (asset source zips are force-added on main)
*.mp4
*.zip
*.rar
*.jpg
*.jpeg
*.part1
*.part2
*.part3
*.7z

# Art / audio are routed through Git LFS in LFS-capable environments
# (see .gitattributes). In this sandbox LFS is unavailable, so PNGs are
# force-added as plain blobs; PNG is therefore NOT ignored here.

# Heavy editing sources & vendor promo junk we never load at runtime.
# (PSDs are recoverable from the original asset zips if ever needed.)
*.psd
*.svg
**/COUPON.pdf
**/COUPON.png
**/*.url

# Extracted audio archives (temporary)
.extracted/
node_modules/
