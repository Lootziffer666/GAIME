# Git LFS — binary art/asset tracking
#
# Raster/vector art and animation/source files are stored via Git LFS so the
# working tree stays usable while large binaries live in the LFS store.
# Note: PNGs committed before LFS was enabled (e.g. composeApp composeResources
# placeholder drawables) remain plain git blobs until they are next modified.
# We deliberately do NOT history-rewrite (git lfs migrate) the shared `main`.

# Pixel art / sprites / atlases / UI
*.png       filter=lfs diff=lfs merge=lfs -text
*.gif       filter=lfs diff=lfs merge=lfs -text

# Animation / tilemap source the game (or Tiled) can consume
*.aseprite  filter=lfs diff=lfs merge=lfs -text
*.ase       filter=lfs diff=lfs merge=lfs -text
*.tmx       filter=lfs diff=lfs merge=lfs -text
*.tsx       filter=lfs diff=lfs merge=lfs -text

# Fonts
*.otf       filter=lfs diff=lfs merge=lfs -text
*.ttf       filter=lfs diff=lfs merge=lfs -text

# Audio (so newly added clips also use LFS; existing bark WAVs stay plain blobs)
*.wav       filter=lfs diff=lfs merge=lfs -text
*.ogg       filter=lfs diff=lfs merge=lfs -text
*.mp3       filter=lfs diff=lfs merge=lfs -text
